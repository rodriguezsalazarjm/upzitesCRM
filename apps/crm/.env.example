# Runtime connection used by Vercel. Use the Supabase pooler URL.
# Example:
# DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"
DATABASE_URL=""

# Direct connection used by Prisma CLI for migrations and seed.
# Example:
# DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
DIRECT_URL=""

CRM_SESSION_SECRET="change-me-in-production"
NEXT_PUBLIC_CRM_BASE_URL="http://localhost:3001"
